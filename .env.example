# ── AgentBoard Environment ──────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# All variables are OPTIONAL — AgentBoard has sensible defaults.
# Priority: CLI args > .env > agentboard.toml > built-in defaults

# ── Server ──────────────────────────────────────────────────
AGENTBOARD_PORT=8765
AGENTBOARD_HOST=0.0.0.0

# ── Auth ────────────────────────────────────────────────────
# Set a specific API key, or leave empty to auto-generate on first run.
# Auto-generated key is saved to .api_key file (chmod 0600).
# AGENTBOARD_API_KEY=

# ── Database ────────────────────────────────────────────────
# Path to SQLite database (relative to WORKDIR or absolute).
# Default: agentboard.db (in the project root / WORKDIR).
# AGENTBOARD_DB_PATH=agentboard.db

# ── Config ──────────────────────────────────────────────────
# Path to agentboard.toml (relative to WORKDIR or absolute).
# Default: auto-detect in project root.
# AGENTBOARD_CONFIG=

# ── Timezone ────────────────────────────────────────────────
TZ=Asia/Jakarta
